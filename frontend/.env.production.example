# Next.js Frontend — Production Environment Variables
# Copy this file and fill in the Railway URLs after deployment

# ───────────────────────────────────────────────
# REQUIRED — Set these in Vercel dashboard too
# ───────────────────────────────────────────────

# Your Railway PHP backend URL (replace with actual Railway URL after deploy)
NEXT_PUBLIC_BACKEND_URL=https://YOUR-RAILWAY-APP.railway.app

# API base URL (same as backend + /api/v1)
NEXT_PUBLIC_API_URL=https://YOUR-RAILWAY-APP.railway.app/api/v1
